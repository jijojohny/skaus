# SKAUS Environment Configuration
# Copy to .env and fill in all values before running anything.
# Lines marked [REQUIRED] have no safe default — the app will fail without them.
# ─────────────────────────────────────────────────────────────────────────────

# ── Docker / Compose ──────────────────────────────────────────────────────────
# GitHub username / org that owns the ghcr.io images (used by docker-compose.prod.yml)
GITHUB_REPOSITORY_OWNER=your-github-username

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# For local dev the gateway connects via DATABASE_URL below.
# For production (docker-compose.prod.yml) these are passed directly to the
# postgres container; DATABASE_URL is assembled automatically from them.
POSTGRES_USER=skaus
POSTGRES_PASSWORD=           # [REQUIRED] choose a strong password
POSTGRES_DB=skaus

# Used by the gateway when running outside Docker (local dev / CI)
DATABASE_URL=postgresql://skaus:skaus_dev@localhost:5432/skaus

# ── Gateway API ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
# In production set to your domain: https://skaus.me
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# ── Solana ────────────────────────────────────────────────────────────────────
# Local:     http://localhost:8899
# Devnet:    https://api.devnet.solana.com
# Mainnet:   use a dedicated RPC (Helius / Alchemy / QuickNode) — [REQUIRED in prod]
SOLANA_RPC_URL=http://localhost:8899
SOLANA_CLUSTER=localnet           # localnet | devnet | mainnet-beta
STEALTH_POOL_PROGRAM_ID=EAeFbo2SKK7KGiUwj4WHAYQxVEWFgiU1ygao9rnB7cGq
NAME_REGISTRY_PROGRAM_ID=JAmSyEVzHNCTzC6BETuRQdwK1gLQYUFnzwiVKRVYqpdT

# ── Relayer (gateway inline) ─────────────────────────────────────────────────
RELAYER_PRIVATE_KEY=             # [REQUIRED] base58-encoded keypair of the relayer wallet
RELAYER_FEE_BPS=10               # relay fee in basis points (10 = 0.1 %)
MAX_PENDING_TXS=50

# ── Relayer service (packages/relayer — standalone, port 3002) ────────────────
RELAYER_PORT=3002
RELAYER_MAX_CONCURRENT=5         # max parallel withdrawal jobs
RELAYER_MAX_ATTEMPTS=3           # retry limit per job
RELAYER_POLL_INTERVAL_MS=3000    # queue poll interval (ms)

# ── Helius (real-time Geyser deposit indexing) ────────────────────────────────
# Get a free key at https://www.helius.dev — enables logsSubscribe WebSocket.
# Without this the indexer falls back to polling every 5 s.
HELIUS_API_KEY=                  # leave blank to use polling only
HELIUS_WS_URL=                   # optional: override the derived wss:// URL

# ── ZK Compression (Light Protocol) ──────────────────────────────────────────
# Set to 'false' in local dev if you don't have a Photon indexer running.
ZK_COMPRESSION_ENABLED=false     # true in production
LIGHT_RPC_URL=                   # Photon endpoint; defaults to SOLANA_RPC_URL
LIGHT_PROVER_URL=https://prover.lightprotocol.com

# ── URLs ──────────────────────────────────────────────────────────────────────
# Absolute base URL embedded in pay-link responses from POST /requests
# Production: https://skaus.me   Local: http://localhost:4000
WEB_APP_PUBLIC_URL=http://localhost:4000

# ── Web App (Next.js) — baked into the Docker image at build time ─────────────
# These must also be set as GitHub Actions variables/secrets for CI builds.
NEXT_PUBLIC_PRIVY_APP_ID=                                  # [REQUIRED] from privy.io dashboard
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3001              # empty string when nginx proxies on same origin
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PROGRAM_ID=EAeFbo2SKK7KGiUwj4WHAYQxVEWFgiU1ygao9rnB7cGq
NEXT_PUBLIC_NAME_REGISTRY_PROGRAM_ID=JAmSyEVzHNCTzC6BETuRQdwK1gLQYUFnzwiVKRVYqpdT
NEXT_PUBLIC_TOKEN_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
NEXT_PUBLIC_CLUSTER=devnet                                 # devnet | mainnet-beta
NEXT_PUBLIC_DEMO_MODE=false
# Optional: override the base URL used when generating personal pay-link QR codes
# NEXT_PUBLIC_PUBLIC_LINK_BASE=https://skaus.me
