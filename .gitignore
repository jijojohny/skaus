# ===========================================================================
# Dependencies
# ===========================================================================
node_modules/
.pnpm-store/

# ===========================================================================
# Build outputs
# ===========================================================================
dist/
build/
target/
.next/
out/
*.tsbuildinfo

# ===========================================================================
# Anchor / Solana
# ===========================================================================
.anchor/
programs/**/target/
test-ledger/

# Program deploy keypairs — these are the PRIVATE KEYS that control program
# upgrade authority. NEVER commit these.
**/deploy/*-keypair.json
**/deploy/*.so

# ===========================================================================
# Environment & secrets
# ===========================================================================
.env
.env.*
# Allow committed env templates (any path, including .env.*.example)
!.env*.example
config/.env.*

# Tooling that often holds local secrets / tokens
.envrc
.vercel/
.netrc
.npmrc
application_default_credentials.json

# Local Docker Compose overrides (may contain real credentials)
docker-compose.override.yml

# Wallet / keypair files
*.key
*.pem
*.p12
*.pfx
**/id.json
*keypair*.json
wallet.json
authority.json

# Relayer private keys
relayer-*.json

# Generic secrets / credentials
secrets.json
credentials.json
.secret
*.secret
service-account*.json

# ===========================================================================
# ZK artifacts (large, regenerated from source)
# ===========================================================================
circuits/*/build/
circuits/*/keys/
*.ptau
*.zkey
*.wasm
*.r1cs
*.sym
circuits/**/pot*.ptau
circuits/**/verification_key.json
circuits/**/proving_key.json

# Trusted setup ceremony outputs
**/powersOfTau*
**/ceremony/

# ===========================================================================
# IDE
# ===========================================================================
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~

# ===========================================================================
# OS
# ===========================================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ===========================================================================
# Logs
# ===========================================================================
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ===========================================================================
# Test & coverage
# ===========================================================================
coverage/
.nyc_output/
lcov.info

# ===========================================================================
# Misc
# ===========================================================================
*.bak
*.tmp
*.orig
.cache/
