# ===========================================================================
# Dependencies
# ===========================================================================
node_modules/
.pnpm-store/

# ===========================================================================
# Build outputs
# ===========================================================================
dist/
build/
target/
.next/
out/
*.tsbuildinfo

# ===========================================================================
# Anchor / Solana
# ===========================================================================
.anchor/
programs/**/target/
test-ledger/

# Program deploy keypairs — these are the PRIVATE KEYS that control program
# upgrade authority. NEVER commit these.
**/deploy/*-keypair.json
**/deploy/*.so

# ===========================================================================
# Environment & secrets
# ===========================================================================
.env
.env.*
!.env.example
config/.env.*

# Wallet / keypair files
*.key
*.pem
**/id.json
*keypair*.json

# Relayer private keys
relayer-*.json

# ===========================================================================
# ZK artifacts (large, regenerated from source)
# ===========================================================================
circuits/*/build/
circuits/*/keys/
*.ptau
*.zkey
*.wasm
*.r1cs
*.sym
circuits/**/pot*.ptau
circuits/**/verification_key.json
circuits/**/proving_key.json

# Trusted setup ceremony outputs
**/powersOfTau*
**/ceremony/

# ===========================================================================
# IDE
# ===========================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ===========================================================================
