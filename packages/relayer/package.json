{
  "name": "@skaus/relayer",
  "version": "0.1.0",
  "private": true,
  "description": "SKAUS withdrawal relayer service — job queue + gas abstraction",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
